[Unit]
Description=MMM Quran Voice Listener for user %i
After=network-online.target sound.target bluetooth.service ollama.service
Wants=network-online.target bluetooth.service
StartLimitIntervalSec=120
StartLimitBurst=20

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/MagicMirror-Pi5/magicmirror/modules/MMM-QuranDisplay
Environment=PYTHONUNBUFFERED=1
Environment=OMP_NUM_THREADS=2
Environment=OPENBLAS_NUM_THREADS=2
Environment=NUMEXPR_NUM_THREADS=2
Environment=HEARTBEAT_FILE=/home/%i/MagicMirror-Pi5/magicmirror/modules/MMM-QuranDisplay/logs/voice_listener.heartbeat
Environment=VOICE_DEVICE=pulse
Environment=VOICE_REQUIRE_PULSE=1
Environment=VOICE_SINK=bluez_output.FC_A8_9A_F6_FB_DA.1
Environment=VOICE_SINK_VOLUME=50%
Environment=VOICE_APPLY_SINK_VOLUME_ON_START=1
Environment=VOICE_ENFORCE_SINK_VOLUME=0
Environment=VOICE_SOURCE=alsa_input.usb-ME6S_MS_N-B_R-UN_ME6S-00.mono-fallback
Environment=VOICE_SOURCE_VOLUME=120%
Environment=VOICE_PULSE_WAIT_SEC=30
Environment=VOICE_AUTO_HEAL_SINK=1
Environment=VOICE_AUTO_HEAL_INTERVAL_SEC=5
Environment=VOICE_FOLLOWUP_WINDOW_SEC=2
Environment=VOICE_COMMAND_DEBOUNCE_SEC=3
Environment=VOICE_BT_CARD=bluez_card.FC_A8_9A_F6_FB_DA
Environment=VOICE_BT_PROFILE=a2dp-sink
Environment=QURAN_MPV_AO=pulse
Environment=QURAN_MPV_AUDIO_DEVICE=pulse/bluez_output.FC_A8_9A_F6_FB_DA.1
Environment=QURAN_PULSE_SINK=bluez_output.FC_A8_9A_F6_FB_DA.1
Environment=QURAN_PULSE_SINK_VOLUME=50%
Environment=QURAN_PULSE_ENFORCE_SINK_VOLUME=0
Environment=QURAN_PULSE_SINK_WAIT_SEC=8
Environment=QURAN_PULSE_CARD=bluez_card.FC_A8_9A_F6_FB_DA
Environment=QURAN_PULSE_CARD_PROFILE=a2dp-sink
Environment=QURAN_MPV_FALLBACK_TO_DEFAULT_SINK=1
Environment=QURAN_MPV_STABLE_AUDIO=1
Environment=QURAN_MPV_SAMPLE_RATE=48000
Environment=QURAN_MPV_ENABLE_DYNAUDNORM=1
Environment=QURAN_MPV_DYNAUDNORM_PARAMS=f=150:g=7:p=0.9:m=10
ExecStartPre=/usr/bin/test -x /home/%i/MagicMirror-Pi5/magicmirror/modules/MMM-QuranDisplay/start_listener.sh
ExecStart=/bin/bash /home/%i/MagicMirror-Pi5/magicmirror/modules/MMM-QuranDisplay/start_listener.sh
Restart=always
RestartSec=5
TimeoutStartSec=45
TimeoutStopSec=15
KillSignal=SIGTERM
Nice=5
IOSchedulingClass=best-effort
IOSchedulingPriority=6
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
