#!/bin/sh
# User-level labwc autostart additions.
# Pi OS's system default (/etc/xdg/labwc/autostart) is loaded separately by
# labwc and handles panels, file manager desktop, kanshi, and XDG autostart.
# This file ONLY adds MagicMirror so we don't duplicate the desktop env.

# Wait briefly for panel/desktop to settle, then launch MM via lwrespawn for
# crash recovery. Log to /tmp so we can inspect failures.
(
  sleep 8
  exec /usr/bin/lwrespawn /bin/sh -c 'cd "$HOME/MagicMirror-Pi5/magicmirror" && exec /usr/bin/npm run start' >> /tmp/mm-autostart.log 2>&1
) &
